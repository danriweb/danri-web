{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@dom": ["./src/shared/lib/dom"],
      "@viewport": ["./src/shared/lib/viewport"],
      "@styles": ["./src/shared/lib/styles"],

      "@data": ["./src/shared/model"],

      "@shadcn": ["./src/shared/ui/shadcn"],
      "@constructors": ["./src/shared/ui/constructors"],
      "@custom-ui": ["./src/shared/ui/custom"],

      "@config": ["./src/shared/config"],

      "@assets/*": ["./src/shared/assets/*"],
      "@assets": ["./src/shared/assets"],

      "@providers": ["./src/app/[locale]/providers"],

      "@i18n": ["./src/i18n"],
      "@app/*": ["./src/app/*"],
      "@widgets/*": ["./src/widgets/*"],
      "@features/*": ["./src/features/*"],
      "@entities/*": ["./src/entities/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", ".next/dev/types/**/*.ts", "**/*.mts"],
  "exclude": ["node_modules"]
}
