{
  "name": "danri-web",
  "version": "0.1.0",
  "private": true,
  "description": "Официальный сайт-визитка Frontend разработчика DanriWeb.",
  "author": "danriweb",
  "scripts": {
    "analyze": "next build --webpack",
    "analyze:client": "webpack-bundle-analyzer --mode static .next/analyze/client.html --report stdout",
    "analyze:edge": "webpack-bundle-analyzer --mode static .next/analyze/edge.html --report stdout",
    "analyze:nodejs": "webpack-bundle-analyzer --mode static .next/analyze/nodejs.html --report stdout",
    "build": "next build",
    "dev": "next dev",
    "lint": "eslint",
    "prepare": "husky",
    "start": "next start",
    "steiger": "npx steiger ./src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@react-icons/all-files": "^4.1.0",
    "@tanstack/query-async-storage-persister": "^5.90.24",
    "@tanstack/query-sync-storage-persister": "^5.90.24",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-persist-client": "^5.90.24",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.36.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-icons": "^5.6.0",
    "react-loading-skeleton": "^3.5.0",
    "react-resizable-panels": "^4.7.2",
    "recharts": "^2.15.4",
    "shadcn": "^4.0.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@conarti/eslint-plugin-feature-sliced": "^1.0.5",
    "@feature-sliced/steiger-plugin": "^0.5.7",
    "@next/bundle-analyzer": "^16.2.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier-plugin-organize-attributes": "^1.0.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react-scan": "^0.5.3",
    "steiger": "^0.5.11",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  }
}
